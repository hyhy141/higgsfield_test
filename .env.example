# ─────────────────────────────────────────────────────────────────────────────
# Example environment file — COMMITTED AS DOCUMENTATION.
# Copy to a local, git-ignored .env to override:  cp .env.example .env
#
# Every value is OPTIONAL. The service boots and serves traffic with NO .env at
# all: `docker compose up -d` works on a clean machine. Embeddings + reranking run
# locally (no key, no network); extraction degrades to a deterministic rule-based
# engine when no LLM key is present.
# ─────────────────────────────────────────────────────────────────────────────

# Optional. If set, enables OpenAI-powered extraction.
# If empty or missing, the service uses deterministic rule-based extraction.
OPENAI_API_KEY=

# Optional. OpenAI model used only when OPENAI_API_KEY is present.
OPENAI_MODEL=gpt-4o-mini

# Optional. Also supported: Anthropic (set ANTHROPIC_API_KEY). Provider selection:
#   auto (default) -> Anthropic if its key is set, else OpenAI if its key is set,
#                     else the rule-based engine. Force with: anthropic|openai|rules.
ANTHROPIC_API_KEY=
EXTRACTION_PROVIDER=auto
# Optional explicit model override (takes precedence over OPENAI_MODEL / the
# Anthropic default claude-3-5-haiku-latest).
EXTRACTION_MODEL=

# Optional. If set, ALL endpoints except GET /health require the header:
#   Authorization: Bearer <MEMORY_AUTH_TOKEN>
# If empty or missing, authentication is disabled.
MEMORY_AUTH_TOKEN=

# Database connection. Set automatically by docker-compose to the bundled
# Postgres+pgvector service; override only for local (non-Docker) runs.
DATABASE_URL=postgresql://memory:memory@db:5432/memory

# HTTP service port.
PORT=8080

# Logging level (info|debug|warning|error).
LOG_LEVEL=info

# Maximum accepted request body size (bytes) for POST /turns. Larger -> 413.
MAX_TURN_BYTES=200000

# ── Local embeddings / reranking (fastembed, baked into the image; no key) ───
EMBED_MODEL=BAAI/bge-small-en-v1.5
RERANK_MODEL=Xenova/ms-marco-MiniLM-L-6-v2

# ── Recall tuning (sensible defaults; override to experiment) ────────────────
RECALL_GATE_TURN_COSINE=0.62
RECALL_GATE_MEMORY_COSINE=0.66
RECALL_QUERY_DECOMPOSITION=true
