# ─────────────────────────────────────────────────────────────────────────────
# Memory service configuration. All values are OPTIONAL — the service boots and
# serves traffic with an empty .env (extraction degrades to the rule-based engine,
# embeddings/reranking run locally and need no keys).
# Copy to `.env` to override: `cp .env.example .env`
# ─────────────────────────────────────────────────────────────────────────────

# Optional bearer token. If set, every endpoint except /health requires the
# header `Authorization: Bearer <token>`. Leave empty to disable auth entirely.
MEMORY_AUTH_TOKEN=

# ── Extraction LLM ───────────────────────────────────────────────────────────
# Which LLM turns raw conversation into structured memories.
#   auto      -> use Anthropic if ANTHROPIC_API_KEY is set, else OpenAI if
#                OPENAI_API_KEY is set, else the deterministic rule-based engine.
#   anthropic -> force Anthropic
#   openai    -> force OpenAI
#   rules     -> force the rule-based engine (no API calls, fully offline)
EXTRACTION_PROVIDER=auto

# Optional model override. Defaults:
#   anthropic -> claude-3-5-haiku-latest   (fast, cheap, strong at structured extraction)
#   openai    -> gpt-4o-mini
# If the configured model/key is invalid at runtime, the service logs a warning
# and falls back to the rule-based engine — it never crashes a /turns request.
EXTRACTION_MODEL=

# API keys (provide whichever provider you want for extraction; both optional).
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# ── Embeddings & reranking (local, no key required) ──────────────────────────
# Run locally via fastembed (ONNX, CPU). Models are baked into the image at build
# time, so the running container needs no network for retrieval.
EMBED_MODEL=BAAI/bge-small-en-v1.5
RERANK_MODEL=Xenova/ms-marco-MiniLM-L-6-v2

# ── Database ─────────────────────────────────────────────────────────────────
# Set automatically by docker-compose; override only for local (non-Docker) runs.
# DATABASE_URL=postgresql://memory:memory@localhost:5432/memory

# ── Recall tuning (sensible defaults; override to experiment) ────────────────
# Minimum reranker score (0..1) for a memory/turn to count as "relevant".
# Below this, /recall returns empty context instead of forcing noise in.
RECALL_RELEVANCE_THRESHOLD=0.04
# Enable LLM query decomposition for multi-hop questions (needs an LLM key).
RECALL_QUERY_DECOMPOSITION=true
